# E2E тест-аккаунты (этап D). Скопируй в .env.test и впиши реальные значения.
# .env.test в .gitignore — в репозиторий не попадёт. Заводи ОТДЕЛЬНЫЕ
# тест-аккаунты, не свои личные.
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=
E2E_EMAIL=user@example.com
E2E_PASSWORD=
# id тест-модуля «E2E-ТЕСТ» (можно оставить — уже подставлен в e2e/config.js)
E2E_MODULE_ID=
